# Optional: provide a logged-in Threads cookie to increase access beyond public limits.
# How to get it (Chrome/Edge):
# 1) Login to https://www.threads.net
# 2) Open DevTools -> Network -> click a request to threads.net
# 3) Copy the full Request Header value for "Cookie" and paste here
THREADS_COOKIE=

# Optional: use a persistent Playwright browser profile.
# This lets you login once (set playwright_headless=false), then reuse that session.
PLAYWRIGHT_USER_DATA_DIR=data/playwright-profile
